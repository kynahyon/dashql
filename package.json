{
  "name": "dashql",
  "version": "0.1.0",
  "description": "DashQL - A SQL-based dashboard query language and runtime",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bazel build //...",
    "test": "bazel test //...",
    "lint": "eslint 'packages/**/*.{ts,tsx}'",
    "lint:fix": "eslint --fix 'packages/**/*.{ts,tsx}'",
    "format": "prettier --write 'packages/**/*.{ts,tsx,json,md}'",
    "format:check": "prettier --check 'packages/**/*.{ts,tsx,json,md}'",
    "typecheck": "tsc --noEmit",
    "clean": "bazel clean",
    "clean:full": "bazel clean --expunge",
    "dev": "bazel run //packages/app:dev_server"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "yarn": ">=4.0.0"
  },
  "packageManager": "yarn@4.1.1"
}
